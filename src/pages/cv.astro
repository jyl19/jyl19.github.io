---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title={`CV | ${site.name}`} description="Download the current CV.">
  <section class="panel">
    <div class="eyebrow">CV</div>
    <h1>Curriculum Vitae</h1>
    <p class="lede">
      Download the current full CV below.
    </p>
    <div class="cta-row">
      <a class="button primary" href="/files/lerner_cv_2026.pdf">Download Full CV (PDF)</a>
    </div>
    <p class="section">
      This page is intentionally simple so the PDF can be replaced in one place without editing the rest of the site.
    </p>
  </section>
</BaseLayout>
