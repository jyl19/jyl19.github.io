---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title={`CV | ${site.name}`} description="Current CV for Joshua Y. Lerner.">
  <section class="panel">
    <div class="eyebrow">CV</div>
    <h1>Curriculum Vitae</h1>
    <p class="lede">
      Download the current full CV.
    </p>
    <div class="cta-row">
      <a class="button primary" href="/files/lerner_cv_2026.pdf">Download Full CV (PDF)</a>
    </div>
    <p class="section">
      Last updated: April 2026.
    </p>
  </section>
</BaseLayout>
