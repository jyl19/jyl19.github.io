---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getPaperMetadataPath,
  getPaperPagePath,
  getPaperPdfPath,
  getPaperSlug,
  paperItems,
  type PaperItem
} from "../../data/publications";
import { paperScholarMetadata } from "../../data/paperScholarMetadata";
import { site } from "../../data/site";

export function getStaticPaths() {
  return paperItems.map((item) => ({
    params: { slug: getPaperSlug(item) },
    props: { item }
  }));
}

const { item } = Astro.props as { item: PaperItem };
const slug = getPaperSlug(item);
const scholarMetadata = paperScholarMetadata[slug] ?? {};
const pagePath = getPaperPagePath(item) ?? `/publications/${slug}/`;
const pdfPath = getPaperPdfPath(item);
const metadataPath = getPaperMetadataPath(item);
const pdfUrl = pdfPath ? new URL(pdfPath, site.url).toString() : undefined;
const metadataUrl = new URL(metadataPath, site.url).toString();
const pageUrl = new URL(pagePath, site.url).toString();

const title = item.title;
const status =
  "status" in item && item.status
    ? item.status
    : item.paperStatus === "published" || ("year" in item && item.year)
      ? "Published article"
      : "Working paper";
const venue = "venue" in item ? item.venue : undefined;
const year = "year" in item ? item.year : undefined;
const doi = "doi" in item ? item.doi : undefined;
const externalHref = item.href;
const citationTitle = scholarMetadata.citationTitle ?? title;
const abstract =
  scholarMetadata.fullAbstract ?? item.fullAbstract ?? ("abstract" in item ? item.abstract : item.note) ?? "";
const extraAuthors =
  item.authors
    ?.replace(/^with\s+/i, "")
    .split(/,\s+and\s+|\s+and\s+|,\s+/)
    .map((author) => author.trim())
    .filter(Boolean) ?? [];
const citationAuthors =
  scholarMetadata.citationAuthors ?? item.citationAuthors ?? ["Lerner, Joshua Y.", ...extraAuthors];
const displayAuthors = citationAuthors
  .map((author) => {
    const [family, given] = author.split(",").map((part) => part?.trim());
    return given ? `${given} ${family}` : author;
  })
  .join(", ");
const hasPdf = Boolean(pdfPath);
const citationPublicationDate =
  scholarMetadata.citationPublicationDate ?? item.citationPublicationDate ?? year;
const citationJournalTitle =
  scholarMetadata.citationJournalTitle ?? item.citationJournalTitle ?? venue;
const citationDoi = scholarMetadata.citationDoi ?? doi;

const citationMeta = [
  { name: "citation_title", content: citationTitle },
  ...citationAuthors.map((author) => ({ name: "citation_author", content: author })),
  { name: "citation_publication_date", content: citationPublicationDate },
  { name: "citation_pdf_url", content: pdfUrl },
  { name: "citation_abstract", content: abstract },
  { name: "citation_journal_title", content: citationJournalTitle },
  { name: "citation_volume", content: scholarMetadata.citationVolume ?? item.citationVolume },
  { name: "citation_issue", content: scholarMetadata.citationIssue ?? item.citationIssue },
  { name: "citation_firstpage", content: scholarMetadata.citationFirstPage ?? item.citationFirstPage },
  { name: "citation_lastpage", content: scholarMetadata.citationLastPage ?? item.citationLastPage },
  { name: "citation_doi", content: citationDoi },
  {
    name: "citation_technical_report_institution",
    content: scholarMetadata.citationTechnicalReportInstitution
  },
  { name: "citation_technical_report_number", content: scholarMetadata.citationTechnicalReportNumber }
];
---

<BaseLayout
  title={`${title} | ${site.name}`}
  description={abstract || `${title} by ${displayAuthors}.`}
  type="article"
  headMeta={citationMeta}
>
  <article class="panel paper-detail">
    <div class="eyebrow">Publication</div>
    <h1>{title}</h1>
    <p class="lede">{displayAuthors}</p>
    <dl class="paper-facts">
      <div>
        <dt>Status</dt>
        <dd>{status}</dd>
      </div>
      {year && (
        <div>
          <dt>Year</dt>
          <dd>{year}</dd>
        </div>
      )}
      {citationPublicationDate && citationPublicationDate !== year && (
        <div>
          <dt>Version Date</dt>
          <dd>{citationPublicationDate}</dd>
        </div>
      )}
      {citationTitle !== title && (
        <div>
          <dt>PDF Title</dt>
          <dd>{citationTitle}</dd>
        </div>
      )}
      {venue && (
        <div>
          <dt>Venue</dt>
          <dd>{venue}</dd>
        </div>
      )}
      {doi && (
        <div>
          <dt>DOI</dt>
          <dd>{doi}</dd>
        </div>
      )}
    </dl>

    <div class="pub-meta paper-actions">
      {pdfPath && <a class="pub-link" href={pdfPath}>Download PDF</a>}
      {externalHref && <a class="pub-link" href={externalHref}>External record</a>}
      <a class="pub-link" href={metadataPath}>Machine-readable metadata</a>
      <a class="pub-link" href="/publications/">All publications</a>
    </div>

    <section class="paper-section">
      <h2>{scholarMetadata.fullAbstract || item.fullAbstract ? "Abstract" : "Summary"}</h2>
      {abstract ? <p>{abstract}</p> : <p>No abstract is posted yet.</p>}
    </section>

    <section class="paper-section">
      <h2>Citation and Files</h2>
      <ul class="paper-links">
        <li>Landing page: <a href={pagePath}>{pageUrl}</a></li>
        {pdfUrl && <li>PDF: <a href={pdfPath}>{pdfUrl}</a></li>}
        {!hasPdf && <li>PDF: not posted</li>}
        <li>Metadata: <a href={metadataPath}>{metadataUrl}</a></li>
        {externalHref && <li>External record: <a href={externalHref}>{externalHref}</a></li>}
      </ul>
    </section>
  </article>
</BaseLayout>
