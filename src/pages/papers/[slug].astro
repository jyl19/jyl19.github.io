---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getPaperMetadataPath,
  getPaperPdfPath,
  getPaperSlug,
  paperCorpusBasePath,
  paperItems,
  type PaperItem
} from "../../data/publications";
import { paperScholarMetadata } from "../../data/paperScholarMetadata";
import { site } from "../../data/site";

export function getStaticPaths() {
  return paperItems.map((item) => ({
    params: { slug: getPaperSlug(item) },
    props: { item }
  }));
}

const { item } = Astro.props as { item: PaperItem };
const slug = getPaperSlug(item);
const getPaperHtmlPagePath = () => `${paperCorpusBasePath}/${slug}/`;
const scholarMetadata = paperScholarMetadata[slug] ?? {};
const pagePath = getPaperHtmlPagePath();
const pdfPath = getPaperPdfPath(item);
const metadataPath = getPaperMetadataPath(item);
const summaryPath = metadataPath.replace(/metadata\.json$/, "summary.md");
const pdfUrl = pdfPath ? new URL(pdfPath, site.url).toString() : undefined;
const metadataUrl = new URL(metadataPath, site.url).toString();
const summaryUrl = new URL(summaryPath, site.url).toString();
const pageUrl = new URL(pagePath, site.url).toString();

const title = item.title;
const status =
  item.displayStatus ??
  ("status" in item && item.status
    ? item.status
    : "section" in item && item.section === "other"
      ? "Other writing"
      : item.paperStatus === "published" || ("year" in item && item.year)
      ? "Published article"
      : "Working paper");
const venue = "venue" in item ? item.venue : undefined;
const year = "year" in item ? item.year : undefined;
const doi = "doi" in item ? item.doi : undefined;
const externalHref = item.href ?? (doi ? `https://doi.org/${doi}` : undefined);
const citationTitle = scholarMetadata.citationTitle ?? title;
const abstract =
  scholarMetadata.fullAbstract ?? item.fullAbstract ?? ("abstract" in item ? item.abstract : item.note) ?? "";
const extraAuthors =
  item.authors
    ?.replace(/^with\s+/i, "")
    .split(/,\s+and\s+|\s+and\s+|,\s+/)
    .map((author) => author.trim())
    .filter(Boolean) ?? [];
const citationAuthors =
  scholarMetadata.citationAuthors ?? item.citationAuthors ?? ["Lerner, Joshua Y.", ...extraAuthors];
const displayAuthors = citationAuthors
  .map((author) => {
    const [family, given] = author.split(",").map((part) => part?.trim());
    return given ? `${given} ${family}` : author;
  })
  .join(", ");
const citationPublicationDate =
  scholarMetadata.citationPublicationDate ?? item.citationPublicationDate ?? year;
const citationJournalTitle =
  scholarMetadata.citationJournalTitle ??
  item.citationJournalTitle ??
  ("section" in item && item.section === "peerReviewed" ? venue : undefined);
const citationConferenceTitle =
  scholarMetadata.citationConferenceTitle ??
  item.citationConferenceTitle ??
  ("section" in item && item.section === "other" ? venue : undefined);
const citationDoi = scholarMetadata.citationDoi ?? doi;

const citationMeta = [
  { name: "citation_title", content: citationTitle },
  ...citationAuthors.map((author) => ({ name: "citation_author", content: author })),
  { name: "citation_publication_date", content: citationPublicationDate },
  { name: "citation_online_date", content: scholarMetadata.citationOnlineDate ?? item.citationOnlineDate },
  { name: "citation_pdf_url", content: pdfUrl },
  { name: "citation_doi", content: citationDoi },
  { name: "citation_journal_title", content: citationJournalTitle },
  { name: "citation_conference_title", content: citationConferenceTitle },
  { name: "citation_volume", content: scholarMetadata.citationVolume ?? item.citationVolume },
  { name: "citation_issue", content: scholarMetadata.citationIssue ?? item.citationIssue },
  { name: "citation_firstpage", content: scholarMetadata.citationFirstPage ?? item.citationFirstPage },
  { name: "citation_lastpage", content: scholarMetadata.citationLastPage ?? item.citationLastPage },
  { name: "citation_abstract", content: abstract },
  {
    name: "citation_technical_report_institution",
    content: scholarMetadata.citationTechnicalReportInstitution
  },
  { name: "citation_technical_report_number", content: scholarMetadata.citationTechnicalReportNumber }
];

const paperFacts = [
  { label: "Status", value: status },
  { label: "Year", value: year },
  {
    label: "Version",
    value: citationPublicationDate && citationPublicationDate !== year ? citationPublicationDate : undefined
  },
  { label: "Venue", value: venue },
  { label: "DOI", value: doi },
  { label: "PDF Title", value: citationTitle !== title ? citationTitle : undefined }
].filter((fact) => Boolean(fact.value));

const actionLinks = [
  pdfPath ? { label: "Download PDF", href: pdfPath, primary: true } : undefined,
  externalHref ? { label: doi ? "DOI / record" : "Canonical record", href: externalHref } : undefined,
  { label: "Metadata", href: metadataPath },
  { label: "Summary", href: summaryPath },
  { label: "All publications", href: "/publications/" }
].filter(Boolean);

const fileLinks = [
  { label: "Landing page", href: pagePath, text: pageUrl },
  pdfUrl ? { label: "PDF", href: pdfPath, text: pdfUrl } : { label: "PDF", text: "Not posted" },
  doi ? { label: "DOI", href: `https://doi.org/${doi}`, text: doi } : undefined,
  externalHref ? { label: "Canonical record", href: externalHref, text: externalHref } : undefined,
  { label: "Metadata JSON", href: metadataPath, text: metadataUrl },
  { label: "Summary", href: summaryPath, text: summaryUrl }
].filter(Boolean);
---

<BaseLayout
  title={`${title} | ${site.name}`}
  description={abstract || `${title} by ${displayAuthors}.`}
  type="article"
  canonicalUrl={pageUrl}
  headMeta={citationMeta}
>
  <article class="paper-page">
    <header class="panel paper-hero">
      <div class="eyebrow">{status}</div>
      <h1>{title}</h1>
      <p class="paper-authors">{displayAuthors}</p>
      <div class="paper-actions">
        {actionLinks.map((link) => (
          <a class={link.primary ? "button primary" : "button"} href={link.href}>{link.label}</a>
        ))}
      </div>
    </header>

    <section class="panel paper-main">
      <h2>{scholarMetadata.fullAbstract || item.fullAbstract ? "Abstract" : "Summary"}</h2>
      {abstract ? <p>{abstract}</p> : <p>No abstract or summary is posted yet.</p>}
    </section>

    <section class="section-grid paper-grid">
      <aside class="panel span-4">
        <h2>Details</h2>
        <dl class="paper-facts">
          {paperFacts.map((fact) => (
            <div>
              <dt>{fact.label}</dt>
              <dd>{fact.value}</dd>
            </div>
          ))}
        </dl>
      </aside>

      <aside class="panel span-8">
        <h2>Files and Links</h2>
        <dl class="file-links">
          {fileLinks.map((link) => (
            <div>
              <dt>{link.label}</dt>
              <dd>{link.href ? <a href={link.href}>{link.text}</a> : link.text}</dd>
            </div>
          ))}
        </dl>
      </aside>
    </section>
  </article>
</BaseLayout>
