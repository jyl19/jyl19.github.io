---
import BaseLayout from "../layouts/BaseLayout.astro";
import { githubProfile, repositories } from "../data/repositories";
import { site } from "../data/site";

const researchRepositories = repositories.filter((repo) => repo.kind !== "Website source");
const siteRepositories = repositories.filter((repo) => repo.kind === "Website source");
---

<BaseLayout
  title={`Code | ${site.name}`}
  description="Selected public code and research-material links for Joshua Y. Lerner."
>
  <section class="panel">
    <div class="eyebrow">Code</div>
    <h1>Selected Code and Research Materials</h1>
    <p class="lede section-intro">
      Public repositories and research materials that are useful outside this website.
    </p>
    <p class="section-intro">
      This page is intentionally selective. The fuller code home is my
      <a href={githubProfile}> GitHub profile</a>; paper-specific replication materials are linked
      from paper pages when they are public.
    </p>
  </section>

  <section class="section-grid">
    <div class="panel span-8">
      <h2>Research Code</h2>
      <div class="list">
        {researchRepositories.map((repo) => (
          <article class="pub">
            <div class="pub-title"><strong>{repo.title}</strong></div>
            <p>{repo.description}</p>
            <div class="pub-meta">
              <span class="status">{repo.kind}</span>
              <span class="status">{repo.language}</span>
              <a class="pub-link" href={repo.href}>View repository</a>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="panel span-4">
      <h2>Site Source</h2>
      <div class="compact-list">
        {siteRepositories.map((repo) => (
          <div class="compact-item">
            <div class="mini-title"><strong>{repo.title}</strong></div>
            <p>{repo.description}</p>
            <a class="pub-link" href={repo.href}>View repository</a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
