---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const resourceLinks = [
  {
    title: "Publications",
    href: "/publications",
    body: "Papers, PDFs, abstracts, and metadata."
  },
  {
    title: "Talks",
    href: "/talks",
    body: "Conference talks, webinars, and short courses."
  },
  {
    title: "Code",
    href: "/code",
    body: "Repositories and replication materials."
  },
  {
    title: "CV",
    href: "/cv",
    body: "Current CV and background."
  },
  {
    title: "Contact",
    href: "/contact",
    body: "Email and collaboration inquiries."
  }
];

const externalProfiles = site.links.filter((link) =>
  ["NORC Profile", "Google Scholar", "GitHub", "LinkedIn"].includes(link.label)
);
---

<BaseLayout title={`${site.name} | ${site.title}`} description={site.hero}>
  <section class="hero home-hero">
    <div class="hero-copy">
      <div class="eyebrow">{site.title}</div>
      <h1>{site.name}</h1>
      <p class="lede">{site.hero}</p>
      <p>{site.intro}</p>
      <div class="cta-row">
        <a class="button primary" href="/publications">Publications</a>
        <a class="button" href="/cv">CV</a>
        <a class="button" href="/contact">Contact</a>
      </div>
    </div>
    <figure class="hero-portrait">
      <img
        src="/images/joshua-lerner-portrait-home.jpg"
        alt="Joshua Y. Lerner headshot"
        width="750"
        height="1000"
      />
    </figure>
  </section>

  <section class="home-directory" aria-labelledby="directory-heading">
    <div class="section-heading">
      <div>
        <div class="eyebrow">Overview</div>
        <h2 id="directory-heading">Work and resources</h2>
      </div>
      <p>Start with the papers. Everything else is here for context.</p>
    </div>
    <div class="directory-grid">
      {resourceLinks.map((item) => (
        <a class="directory-card" href={item.href}>
          <span class="directory-title">{item.title}</span>
          <span>{item.body}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="section-grid">
    <div class="panel span-8">
      <div class="eyebrow">At NORC</div>
      <h2>Senior research methodologist at NORC</h2>
      <p>
        I am a senior research methodologist working across artificial intelligence,
        natural language processing, machine learning, causal inference, and program
        evaluation.
      </p>
      <p>
        At NORC, my work connects these methods to survey methodology, large-scale
        evaluation, AmeriSpeak research, deliberative polling, and the analysis of
        conversational and legislative text.
      </p>
      <p>
        I also publish on Congress, state capacity, public opinion, and the use of
        text as evidence about political institutions.
      </p>
    </div>
    <div class="panel span-4">
      <div class="eyebrow">Elsewhere</div>
      <h2>Profiles</h2>
      <div class="list">
        {externalProfiles.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
