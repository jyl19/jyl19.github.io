---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const directoryItems = [
  {
    number: "01",
    title: "Publications",
    href: "/publications",
    body: "Published articles, working papers, PDFs, abstracts, and metadata."
  },
  {
    number: "02",
    title: "Talks and Teaching",
    href: "/talks",
    body: "Conference presentations, webinars, short courses, and teaching."
  },
  {
    number: "03",
    title: "Code",
    href: "/code",
    body: "Project repositories and replication materials."
  },
  {
    number: "04",
    title: "CV",
    href: "/cv",
    body: "Current CV and professional background."
  },
  {
    number: "05",
    title: "Contact",
    href: "/contact",
    body: "Email, profiles, and collaboration inquiries."
  }
];

const externalProfiles = site.links.filter((link) =>
  ["NORC Profile", "Google Scholar", "GitHub", "LinkedIn"].includes(link.label)
);
---

<BaseLayout title={`${site.name} | ${site.title}`} description={site.hero}>
  <section class="hero home-hero">
    <div class="hero-copy">
      <div class="eyebrow">{site.title}</div>
      <h1>{site.name}</h1>
      <p class="lede">{site.hero}</p>
      <p>{site.intro}</p>
      <div class="cta-row">
        <a class="button primary" href="/publications">Publications</a>
        <a class="button" href="/cv">CV</a>
        <a class="button" href="/contact">Contact</a>
      </div>
    </div>
    <figure class="hero-portrait">
      <img
        src="/images/joshua-lerner-portrait-home.jpg"
        alt="Joshua Y. Lerner headshot"
        width="750"
        height="1000"
      />
    </figure>
  </section>

  <section class="home-directory" aria-labelledby="directory-heading">
    <div class="section-heading">
      <div>
        <div class="eyebrow">Overview</div>
        <h2 id="directory-heading">Work and resources</h2>
      </div>
      <p>
        Publications, talks, code, CV, and contact details are grouped below.
      </p>
    </div>
    <div class="directory-grid">
      {directoryItems.map((item) => (
        <a class="directory-card" href={item.href}>
          <span class="directory-number">{item.number}</span>
          <span class="directory-title">{item.title}</span>
          <span>{item.body}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="section-grid">
    <div class="panel span-8">
      <h2>About the Work</h2>
      <p class="lede">{site.summary}</p>
      {site.bio.map((paragraph) => <p>{paragraph}</p>)}
    </div>
    <div class="panel span-4">
      <h2>External Profiles</h2>
      <div class="list">
        {externalProfiles.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
