---
import BaseLayout from "../layouts/BaseLayout.astro";
import { talks } from "../data/professional";
import { getPaperSlug, paperCorpusBasePath, publications } from "../data/publications";
import { site } from "../data/site";

const featured = publications
  .filter((item) => item.featured)
  .sort((a, b) => b.year - a.year || a.title.localeCompare(b.title))
  .slice(0, 5);

const featuredTalks = talks
  .sort(
    (a, b) =>
      b.year - a.year ||
      Number(Boolean(b.featured)) - Number(Boolean(a.featured)) ||
      a.title.localeCompare(b.title)
  )
  .slice(0, 4);

const getPaperPath = (item) => `${paperCorpusBasePath}/${getPaperSlug(item)}/`;
---

<BaseLayout title={`${site.name} | ${site.title}`} description={site.hero}>
  <section class="hero">
    <div class="hero-heading">
      <div>
        <div class="eyebrow">{site.title}</div>
        <h1>{site.name}</h1>
      </div>
      <img
        class="hero-badge"
        src="/images/joshua-lerner-headshot-square.jpg"
        alt="Joshua Y. Lerner headshot"
        width="5308"
        height="5308"
      />
    </div>
    <p class="lede">{site.hero}</p>
    <p>{site.intro}</p>
    <p>
      For more on my applied work at NORC, see my
      <a href="https://www.norc.org/about/experts/joshua-lerner.html"> NORC experts page</a>.
    </p>
    <div class="cta-row">
      <a class="button primary" href="/publications">View Publications</a>
      <a class="button" href="/cv">Download CV</a>
      <a class="button" href="https://www.norc.org/about/experts/joshua-lerner.html">NORC Profile</a>
    </div>
  </section>

  <section class="section-grid">
    <div class="panel span-12">
      <h2>Signature Projects</h2>
      <p>
        Start here for the projects that best show the range of the work: survey measurement,
        deliberation, legislative text, and state capacity.
      </p>
      <div class="section-grid">
        {site.signatureProjects.map((item) => (
          <article class="span-6 theme-card">
            <div>
              <h3>{item.href ? <a href={item.href}>{item.title}</a> : item.title}</h3>
              <p>{item.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-grid">
    <div class="panel span-8">
      <h2>Approach</h2>
      <p class="lede">{site.summary}</p>
      {site.bio.map((paragraph) => <p>{paragraph}</p>)}
    </div>
    <div class="panel span-4">
      <h2>Quick Links</h2>
      <div class="list">
        {site.links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-grid">
    <div class="panel span-8">
      <h2>Selected Publications</h2>
      <div class="list">
        {featured.map((item) => (
          <article class="pub">
            <div class="pub-title">
              <a href={getPaperPath(item)}><strong>{item.title}</strong></a>
            </div>
            <p>{item.authors ? `${item.authors}. ` : ""}{item.venue}, {item.year}.</p>
            {item.href && (
              <div class="pub-meta">
                <a class="pub-link" href={item.href}>Read article</a>
              </div>
            )}
          </article>
        ))}
      </div>
    </div>

    <div class="panel span-4">
      <h2>Recent Talks</h2>
      <div class="compact-list">
        {featuredTalks.map((talk) => (
          <div class="compact-item">
            <div class="pub-title"><strong>{talk.title}</strong></div>
            <p>{talk.venue}, {talk.year}.</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
