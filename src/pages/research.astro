---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { publicationCategories, publications } from "../data/publications";

const researchSections = publicationCategories.map(([key, label]) => ({
  key,
  label,
  theme: site.themes.find((theme) => theme.key === key),
  items: publications
    .filter((item) => item.section === "peerReviewed" && item.category === key)
    .sort((a, b) => b.year - a.year || a.title.localeCompare(b.title))
    .slice(0, 3)
}));
---

<BaseLayout
  title={`Research | ${site.name}`}
  description="Research on survey methodology, causal inference, political institutions, text, and deliberation."
>
  <section class="panel span-12">
    <div class="eyebrow">Research</div>
    <h1>Research</h1>
    <p class="lede section-intro">
      I work across survey methodology, computational social science, causal inference, and
      political institutions, but those areas are less separate in practice than they often
      appear on paper.
    </p>
    <p class="section-intro">
      Much of my work is about studying social and institutional questions when the core concepts
      are hard to observe directly and the data do not arrive in tidy form.
    </p>
    <p class="section-intro">
      That leads me repeatedly to problems of measurement, construct validity, and research
      design. In some projects the tools are NLP or generative AI. In others, they are
      design-based or econometric methods for causal inference. In both cases, the goal is the
      same: better empirical work on questions that matter.
    </p>
    <div class="anchor-row">
      {researchSections.map((section) => (
        <a class="anchor-link" href={`#${section.key}`}>{section.label}</a>
      ))}
    </div>
  </section>

  <section class="section-grid">
    {researchSections.map((section) => (
      <article class="panel span-6 theme-card" id={section.key}>
        <div>
          <h2>{section.label}</h2>
          <p>{section.theme?.body}</p>
        </div>
        <div>
          <h3>Representative Work</h3>
          <div class="compact-list">
            {section.items.map((item) => (
              <article class="pub">
                <div class="pub-title"><strong>{item.title}</strong></div>
                <p>{item.venue}, {item.year}.</p>
                {item.href && <a class="pub-link" href={item.href}>Read article</a>}
              </article>
            ))}
          </div>
        </div>
      </article>
    ))}
  </section>

  <section class="section-grid">
    <div class="panel span-8">
      <h2>How the Work Fits Together</h2>
      <p>
        A lot of my work lives in the overlap between substantive inquiry and methodological
        development. Survey projects use NLP and generative AI to improve coding and measurement.
        Evaluation work relies on careful design to recover credible causal effects under
        real-world constraints. Institutional work uses text, procedure, and measurement to study
        how political actors behave.
      </p>
      <p>
        The unifying logic is not a commitment to any one method. It is a commitment to
        disciplined empirical research: clear constructs, appropriate tools, and stronger
        inference in settings that are noisy, high-dimensional, or institutionally complex.
      </p>
    </div>
    <div class="panel span-4">
      <h2>Related Pages</h2>
      <div class="compact-list">
        <div class="compact-item">
          <p><a href="/publications">Browse the full publications list</a></p>
        </div>
        <div class="compact-item">
          <p><a href="/cv">Download the current CV</a></p>
        </div>
        <div class="compact-item">
          <p><a href="/contact">Get in touch</a></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
