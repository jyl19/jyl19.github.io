---
import { site } from "../data/site";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
}

const {
  title,
  description = site.summary,
  image = site.socialImage,
  type = "website"
} = Astro.props;

const pathname = Astro.url.pathname || "/";
const normalizedPath = pathname.replace(/\/+$/, "") || "/";
const canonicalUrl = new URL(normalizedPath, Astro.site ?? site.url).toString();
const shareImage = new URL(image, Astro.site ?? site.url).toString();

const navItems = [
  { href: "/research", label: "Research" },
  { href: "/publications", label: "Publications" },
  { href: "/code", label: "Code" },
  { href: "/cv", label: "CV" },
  { href: "/contact", label: "Contact" }
];

const isCurrentPath = (href: string) => normalizedPath === href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={shareImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={site.socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={shareImage} />
    <meta name="twitter:image:alt" content={site.socialImageAlt} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header shell">
      <div class="nav-wrap">
        <a class="brand" href="/" aria-current={normalizedPath === "/" ? "page" : undefined}>
          {site.name}
        </a>
        <nav aria-label="Primary">
          {navItems.map((item) => (
            <a class="nav-link" href={item.href} aria-current={isCurrentPath(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>
    <main class="shell">
      <slot />
    </main>
    <footer class="shell">
      <p>{site.name}</p>
    </footer>
  </body>
</html>
