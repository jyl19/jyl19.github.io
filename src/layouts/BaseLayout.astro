---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Joshua Y. Lerner academic and professional website." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:global>
      :root {
        --bg: #f4f0e8;
        --paper: rgba(255, 252, 247, 0.82);
        --text: #1f2a2c;
        --muted: #566567;
        --line: rgba(31, 42, 44, 0.12);
        --accent: #1c5c59;
        --accent-soft: #dce9e3;
        --shadow: 0 18px 60px rgba(31, 42, 44, 0.1);
        --max: 1100px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family: Georgia, "Iowan Old Style", "Palatino Linotype", serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(28, 92, 89, 0.08), transparent 35%),
          radial-gradient(circle at top right, rgba(196, 159, 93, 0.12), transparent 30%),
          linear-gradient(180deg, #f7f4ee 0%, var(--bg) 100%);
      }

      body {
        margin: 0;
        min-height: 100vh;
      }

      a {
        color: var(--accent);
      }

      .shell {
        width: min(calc(100% - 2rem), var(--max));
        margin: 0 auto;
      }

      header.site-header {
        padding: 1.25rem 0;
      }

      .nav-wrap {
        display: flex;
        gap: 1rem;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.2rem;
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 999px;
        backdrop-filter: blur(10px);
        box-shadow: var(--shadow);
      }

      .brand {
        font-size: 0.98rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        color: var(--text);
      }

      nav {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }

      nav a {
        text-decoration: none;
        color: var(--muted);
      }

      main {
        padding: 1rem 0 4rem;
      }

      .hero,
      .panel {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 28px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(8px);
      }

      .hero {
        padding: 3rem;
      }

      .eyebrow {
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.8rem;
        margin-bottom: 1rem;
      }

      h1, h2, h3 {
        font-weight: 600;
        line-height: 1.1;
        margin: 0 0 1rem;
      }

      h1 {
        font-size: clamp(2.6rem, 6vw, 5rem);
        max-width: 12ch;
      }

      h2 {
        font-size: clamp(1.8rem, 4vw, 2.8rem);
      }

      h3 {
        font-size: 1.2rem;
      }

      p {
        line-height: 1.7;
        color: var(--muted);
        margin: 0 0 1rem;
        font-size: 1.02rem;
      }

      .lede {
        font-size: 1.2rem;
        color: var(--text);
        max-width: 44rem;
      }

      .cta-row,
      .tag-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .button,
      .tag {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        text-decoration: none;
      }

      .button {
        padding: 0.8rem 1.15rem;
        border: 1px solid var(--line);
        color: var(--text);
        background: white;
      }

      .button.primary {
        background: var(--accent);
        color: white;
        border-color: var(--accent);
      }

      .tag {
        padding: 0.45rem 0.85rem;
        background: var(--accent-soft);
        color: var(--accent);
        font-size: 0.92rem;
      }

      .section {
        margin-top: 1.5rem;
      }

      .section-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 1.25rem;
        margin-top: 1.5rem;
      }

      .span-12 { grid-column: span 12; }
      .span-8 { grid-column: span 8; }
      .span-6 { grid-column: span 6; }
      .span-4 { grid-column: span 4; }

      .panel {
        padding: 1.5rem;
      }

      .list {
        display: grid;
        gap: 1rem;
      }

      .compact-list {
        display: grid;
        gap: 0.8rem;
      }

      .compact-item {
        padding-top: 0.8rem;
        border-top: 1px solid var(--line);
      }

      .compact-item:first-child {
        border-top: 0;
        padding-top: 0;
      }

      .pub {
        padding-top: 1rem;
        border-top: 1px solid var(--line);
      }

      .pub:first-child {
        border-top: 0;
        padding-top: 0;
      }

      .pub-title {
        color: var(--text);
        margin-bottom: 0.25rem;
      }

      .pub-meta {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        align-items: center;
      }

      .pub-link {
        font-size: 0.95rem;
        text-decoration: none;
      }

      footer {
        padding: 2rem 0 3rem;
        color: var(--muted);
      }

      @media (max-width: 900px) {
        .span-8,
        .span-6,
        .span-4 {
          grid-column: span 12;
        }

        .nav-wrap {
          border-radius: 24px;
          align-items: flex-start;
          flex-direction: column;
        }

        .hero {
          padding: 2rem;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header shell">
      <div class="nav-wrap">
        <a class="brand" href="/">Joshua Y. Lerner</a>
        <nav>
          <a href="/research">Research</a>
          <a href="/publications">Publications</a>
          <a href="/cv">CV</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </header>
    <main class="shell">
      <slot />
    </main>
    <footer class="shell">
      <p>Built as a static academic-professional site for easy long-term maintenance.</p>
    </footer>
  </body>
</html>
