---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Joshua Y. Lerner academic and professional website." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:global>
      :root {
        --bg: #f5f1ea;
        --paper: rgba(255, 253, 249, 0.78);
        --text: #1d2728;
        --muted: #5b6869;
        --line: rgba(29, 39, 40, 0.1);
        --accent: #1c5c59;
        --accent-soft: #e3eee8;
        --shadow: 0 14px 40px rgba(31, 42, 44, 0.07);
        --max: 1100px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family: "Avenir Next", "Segoe UI", "Helvetica Neue", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(28, 92, 89, 0.07), transparent 34%),
          radial-gradient(circle at top right, rgba(196, 159, 93, 0.09), transparent 28%),
          linear-gradient(180deg, #f8f5ef 0%, var(--bg) 100%);
      }

      body {
        margin: 0;
        min-height: 100vh;
      }

      a {
        color: var(--accent);
      }

      .shell {
        width: min(calc(100% - 2rem), var(--max));
        margin: 0 auto;
      }

      header.site-header {
        padding: 0.95rem 0;
      }

      .nav-wrap {
        display: flex;
        gap: 0.85rem;
        justify-content: space-between;
        align-items: center;
        padding: 0.78rem 1rem;
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 999px;
        backdrop-filter: blur(10px);
        box-shadow: var(--shadow);
      }

      .brand {
        font-size: 0.88rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        color: var(--text);
      }

      nav {
        display: flex;
        gap: 0.9rem;
        flex-wrap: wrap;
      }

      nav a {
        text-decoration: none;
        color: var(--muted);
        font-size: 0.95rem;
      }

      main {
        padding: 0.6rem 0 3rem;
      }

      .hero,
      .panel {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 22px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(8px);
      }

      .hero {
        padding: 2.35rem;
      }

      .hero-heading {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1.25rem;
      }

      .hero-badge {
        display: block;
        width: clamp(72px, 9vw, 104px);
        height: auto;
        flex-shrink: 0;
        border-radius: 18px;
        border: 1px solid var(--line);
        box-shadow: 0 10px 26px rgba(31, 42, 44, 0.11);
      }

      .eyebrow {
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.72rem;
        font-weight: 600;
        margin-bottom: 0.7rem;
      }

      h1, h2, h3 {
        font-weight: 600;
        line-height: 1.08;
        letter-spacing: -0.02em;
        margin: 0 0 0.75rem;
      }

      h1 {
        font-size: clamp(2.15rem, 5vw, 3.85rem);
        max-width: 11ch;
      }

      h2 {
        font-size: clamp(1.3rem, 2.5vw, 1.8rem);
      }

      h3 {
        font-size: 1rem;
      }

      p {
        line-height: 1.58;
        color: var(--muted);
        margin: 0 0 0.85rem;
        font-size: 0.97rem;
      }

      .lede {
        font-size: 1.06rem;
        line-height: 1.5;
        color: var(--text);
        max-width: 40rem;
      }

      .cta-row,
      .tag-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .button,
      .tag {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        text-decoration: none;
      }

      .button {
        padding: 0.68rem 0.95rem;
        border: 1px solid var(--line);
        color: var(--text);
        background: white;
        font-size: 0.92rem;
      }

      .button.primary {
        background: var(--accent);
        color: white;
        border-color: var(--accent);
      }

      .tag {
        padding: 0.34rem 0.68rem;
        background: var(--accent-soft);
        color: var(--accent);
        font-size: 0.82rem;
      }

      .section {
        margin-top: 1rem;
      }

      .section-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 0.95rem;
        margin-top: 0.95rem;
      }

      .span-12 { grid-column: span 12; }
      .span-8 { grid-column: span 8; }
      .span-6 { grid-column: span 6; }
      .span-4 { grid-column: span 4; }

      .panel {
        padding: 1.2rem;
      }

      .list {
        display: grid;
        gap: 0.8rem;
      }

      .compact-list {
        display: grid;
        gap: 0.65rem;
      }

      .compact-item {
        padding-top: 0.7rem;
        border-top: 1px solid var(--line);
      }

      .compact-item:first-child {
        border-top: 0;
        padding-top: 0;
      }

      .pub {
        padding-top: 0.8rem;
        border-top: 1px solid var(--line);
      }

      .pub:first-child {
        border-top: 0;
        padding-top: 0;
      }

      .pub-title {
        color: var(--text);
        margin-bottom: 0.18rem;
      }

      .pub-meta {
        display: flex;
        gap: 0.55rem;
        flex-wrap: wrap;
        align-items: center;
      }

      .pub-link {
        font-size: 0.9rem;
        text-decoration: none;
      }

      .section-intro {
        max-width: 46rem;
      }

      .anchor-row {
        display: flex;
        gap: 0.55rem;
        flex-wrap: wrap;
        margin-top: 1rem;
      }

      .anchor-link {
        font-size: 0.82rem;
        text-decoration: none;
        color: var(--accent);
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 0.36rem 0.64rem;
        background: rgba(255, 255, 255, 0.7);
      }

      .theme-card {
        display: grid;
        gap: 0.9rem;
      }

      .theme-card .pub {
        padding-top: 0.65rem;
      }

      footer {
        padding: 1.4rem 0 2.2rem;
        color: var(--muted);
      }

      @media (max-width: 900px) {
        .span-8,
        .span-6,
        .span-4 {
          grid-column: span 12;
        }

        .nav-wrap {
          border-radius: 18px;
          align-items: flex-start;
          flex-direction: column;
        }

        .hero {
          padding: 1.6rem;
        }

        .hero-heading {
          gap: 0.8rem;
          align-items: flex-start;
        }

        .hero-badge {
          width: 72px;
          border-radius: 16px;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header shell">
      <div class="nav-wrap">
        <a class="brand" href="/">Joshua Y. Lerner</a>
        <nav>
          <a href="/research">Research</a>
          <a href="/publications">Publications</a>
          <a href="/cv">CV</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </header>
    <main class="shell">
      <slot />
    </main>
    <footer class="shell">
      <p>Built as a static academic-professional site for easy long-term maintenance.</p>
    </footer>
  </body>
</html>
